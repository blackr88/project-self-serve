# Database
DATABASE_URL="postgresql://pageamphtml:YOUR_PASSWORD@localhost:5432/pageamphtml?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="https://pageamphtml.com"
NEXT_PUBLIC_APP_DOMAIN="pageamphtml.com"
STORAGE_PATH="/var/www/storage/sites"

# Upload
MAX_UPLOAD_SIZE_MB=10
MAX_PAGES_PER_USER=50

# Node
NODE_ENV="production"
